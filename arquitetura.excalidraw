    {
      "id": "EnRfnJGPNsf0UEtMOsuuw",
      "type": "text",
      "x": 338.2925202357511,
      "y": -228.11229880133988,
      "width": 679.8682574935323,
      "height": 131.0092949248037,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#eebefa",
      "fillStyle": "solid",
      "strokeWidth": 4,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aW",
      "roundness": null,
      "seed": 2104536767,
      "version": 118,
      "versionNonce": 867970869,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775862382357,
      "link": null,
      "locked": false,
      "text": "Uma oficina mecanica de medio porte realiza atendimentos, \ndiagnosticos, execucao de servicos e entrega de veiculos de forma desorganizada, \ncom forte dependencia de anotacoes manuais e planilhas.\n\nEsse modelo operacional gera perda de informacao, erros no fluxo de trabalho e baixa \nprevisibilidade no atendimento ao cliente.",
      "fontSize": 17.467905989973826,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Uma oficina mecanica de medio porte realiza atendimentos, \ndiagnosticos, execucao de servicos e entrega de veiculos de forma desorganizada, \ncom forte dependencia de anotacoes manuais e planilhas.\n\nEsse modelo operacional gera perda de informacao, erros no fluxo de trabalho e baixa \nprevisibilidade no atendimento ao cliente.",
      "autoResize": true,
      "lineHeight": 1.25
    },
