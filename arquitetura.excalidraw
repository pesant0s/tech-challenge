      ],
      "updated": 1775862382357,
      "link": null,
      "locked": false,
      "text": "Gestão administrativa:\n\n    - CRUD de clientes\n\n    - CRUD de veículos\n\n    - CRUD de serviços\n\n    - CRUD de peças e insumos, com controle de estoque\n\n    - Listagem e detalhamento de ordens de serviço\n\n    - Monitoramento do tempo médio de execução dos serviços",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Gestão administrativa:\n\n    - CRUD de clientes\n\n    - CRUD de veículos\n\n    - CRUD de serviços\n\n    - CRUD de peças e insumos, com controle de estoque\n\n    - Listagem e detalhamento de ordens de serviço\n\n    - Monitoramento do tempo médio de execução dos serviços",
      "autoResize": true,
      "lineHeight": 1.25
    },
