      "updated": 1776298265213,
      "link": null,
      "locked": false,
      "text": "Após o envio do orçamento\nao cliente, o sistema\nautomaticamente cria a OS\ncom o status de\nAguardando aprovação.",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
