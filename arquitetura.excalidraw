      "updated": 1776298289122,
      "link": null,
      "locked": false,
      "text": "Em caso das peças e\ninsumos serem obrigatórias\npara o serviço, a OS pode\nser cancelada mantendo o\nregistro do cliente para\nquando tiver estoque",
      "fontSize": 36,
      "fontFamily": 6,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "Gi4OCMdQXgclKa694ysaq",
      "originalText": "Em caso das peças e insumos serem obrigatórias para o serviço, a OS pode ser cancelada mantendo o registro do cliente para quando tiver estoque",
      "autoResize": true,
      "lineHeight": 1.25
    },
